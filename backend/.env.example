APP_ENV=dev
APP_SECRET=change_this_secret

DATABASE_URL="mysql://usuario:password@127.0.0.1:3306/auth_api?serverVersion=8.0&charset=utf8mb4"

# El backend puede seguir teniendo MAILER_DSN, pero para Railway recomendamos la API HTTP de Brevo.
# MAILER_DSN=null://null
# MAILER_FROM=remitente_verificado@example.com
# BREVO_API_KEY=tu_api_key_brevo
# BREVO_SENDER_EMAIL=remitente_verificado@example.com
# BREVO_SENDER_NAME=Citribio
# ORDER_NOTIFICATION_EMAIL=pedidos@example.com
# ─── RESEND (Email Service Provider) ───────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
CONTACT_TO_EMAIL=citribioapp@gmail.com
CONTACT_FROM_EMAIL=onboarding@resend.dev
CONTACT_LOGO_URL=https://citribio-frontend.vercel.app/Citribio_blanco.png
ORDER_NOTIFICATION_EMAIL=pedidos@example.com

FRONTEND_URL=https://your-frontend-domain.com
CITRIBIO_BANK_IBAN="ES00 0000 0000 0000 0000 0000"

# Logo URLs used in transactional emails
# LOGO_GRANDE_URL: white logo for dark/green email headers
# LOGO_PEQUENO_URL: colour logo for footers or light backgrounds
LOGO_GRANDE_URL=https://citribio-frontend.vercel.app/Citribio_blanco.png
LOGO_PEQUENO_URL=https://citribio-frontend.vercel.app/Citribio.png

CORS_ALLOW_ORIGINS=https://citribio-frontend.vercel.app,http://localhost:4200,http://127.0.0.1:4200
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With,Accept,Origin

JWT_PASSPHRASE=change_this_passphrase
