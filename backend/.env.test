# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# SQLite in-memory database — no external DB required for tests
DATABASE_URL="sqlite:///%kernel.project_dir%/var/test.db"

# JWT — passphrase must match the one used to generate config/jwt/private.pem
JWT_PASSPHRASE=test_passphrase
# Mailer — null transport, no emails sent during tests
MAILER_DSN=null://null
MAILER_FROM="Citribio Test <test@example.com>"

# Resend — not used in tests
RESEND_API_KEY=test_key_not_used

# Contact / order notification — required by service wiring
CONTACT_TO_EMAIL=test@example.com
CONTACT_FROM_EMAIL="Citribio Test <test@example.com>"
CONTACT_LOGO_URL=https://example.com/logo.png
ORDER_NOTIFICATION_EMAIL=test@example.com

# CORS — not relevant for tests
CORS_ALLOW_ORIGINS=http://localhost:4200
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization
